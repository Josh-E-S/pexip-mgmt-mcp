# =============================================================================
# Pexip Management MCP - configuration
# Copy to .env and fill in. All variables are PEXIP_* prefixed and are loaded
# from this .env file or from the process environment.
# =============================================================================

# --- Connection ---------------------------------------------------------------
# The Pexip Management Node hostname or IP (no scheme, no path).
PEXIP_HOST=pexip-mgr.example.com


# --- Authentication mode ------------------------------------------------------
# How THIS server authenticates to the Pexip Management API. Two modes:
#
#   oauth2  (RECOMMENDED) - an OAuth2 client using an ES256 JWT assertion. The
#           server signs a short-lived JWT with your client's private key and
#           exchanges it for a 1-hour bearer token (cached + auto-refreshed).
#           Preferred for production: no reusable admin password sits in the
#           environment, and it authenticates once per hour instead of on every
#           request. Requires one-time setup in the Pexip UI (see below).
#
#   basic   (default)     - a local Management Node admin username + password.
#           Works on every Infinity out of the box; simplest for getting started
#           and for lab / loopback use. Sends admin credentials on each request.
#
# Unset defaults to "basic". Set to "oauth2" to use the recommended mode.
# PEXIP_AUTH_MODE=oauth2


# --- OAuth2 auth  (RECOMMENDED; PEXIP_AUTH_MODE=oauth2) -----------------------
# OAuth2 is NOT enabled on Infinity by default. First, in the Pexip admin UI:
#   1. create an Administrator Role,
#   2. add an OAuth2 client (Users & Devices > OAuth2 Clients) and copy its
#      Client ID + Private key (the private key is shown only once), then
#   3. enable Management API OAuth2 (Users & Devices > Administrator Authentication).
# Then set the two values below.
# PEXIP_OAUTH2_CLIENT_ID=your-client-id
#
# Paste the client's "Private key" (ES256 PEM, shown once on creation). For a
# multi-line PEM, quote it and use \n, or load it from a file in your launcher.
# PEXIP_OAUTH2_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Optional overrides:
# PEXIP_OAUTH2_TOKEN_URL=https://pexip.example.com/oauth/token/   # default: https://<host>/oauth/token/
# PEXIP_OAUTH2_SCOPE="is_admin use_api"                           # default scopes


# --- Basic auth  (default; PEXIP_AUTH_MODE=basic) ----------------------------
# Local Management Node admin username + password. Used when PEXIP_AUTH_MODE is
# unset or "basic"; ignored in oauth2 mode.
PEXIP_USERNAME=admin
PEXIP_PASSWORD=password


# --- TLS ----------------------------------------------------------------------
# Enforce trusted SSL certificates. Set to false ONLY for a local/lab node with
# a self-signed cert - never in production.
PEXIP_VERIFY_TLS=true


# --- HTTP tuning --------------------------------------------------------------
# PEXIP_TIMEOUT=30        # HTTP request timeout in seconds (default: 30)
# PEXIP_MAX_RETRIES=3     # retries on 429 rate-limit responses (default: 3)


# --- Safety: read-only + write gating -----------------------------------------
# Read-only mode is ON BY DEFAULT (secure by default): only read tools
# (list/get/schema) are exposed, and every create/update/delete/control tool is
# removed from the catalog at startup. Set to false to OPT IN to writes.
# PEXIP_READ_ONLY=true
#
# When writes are enabled, the generic CRUD tools still refuse to mutate
# security-critical resources (SSH authorized keys, admin roles/permissions,
# authentication/SSO config, TLS/CA certificates) unless you opt in here.
# Leave false unless you really need it.
# PEXIP_ALLOW_SECURITY_RESOURCES=false
#
# Platform-lifecycle command tools (backup create/restore, certificate import,
# platform upgrade, software-bundle upload, cloud-node start, snapshot) are
# removed at startup even with writes enabled, unless you opt in here. Misuse of
# any of these can replace or compromise the whole platform. Leave false unless
# you deliberately need agent-driven platform lifecycle operations.
# PEXIP_ALLOW_PLATFORM_TOOLS=false


# --- Downstream auth: how HTTP clients authenticate to THIS server ------------
# Only affects the --http transport; the default stdio transport needs none of
# this. See docs/identity.md.
#
# PEXIP_MCP_AUTH_MODE: "token" (default, static bearer) or "oauth" (validate OIDC
# bearer JWTs from your own IdP - Entra/Google/Okta/on-prem).
# PEXIP_MCP_AUTH_MODE=token
#
# token mode: a shared secret set here AND sent by the client as
# "Authorization: Bearer <value>". REQUIRED for a non-loopback bind. Must be >= 32
# chars (the server refuses shorter). Generate one:  pexip-mgmt-mcp --generate-token
# PEXIP_MCP_TOKEN=replace-with-long-random-string
#
# oauth mode (PEXIP_MCP_AUTH_MODE=oauth): point at an OIDC provider you already
# run. Issuer + audience are required; JWKS is discovered from the issuer if unset.
# PEXIP_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# PEXIP_OIDC_AUDIENCE=api://pexip-mcp
# PEXIP_OIDC_REQUIRED_SCOPES="pexip.read pexip.write"
# PEXIP_OIDC_JWKS_URI=https://your-idp/.well-known/jwks.json


# --- Eval suite (evals/) - developers only ------------------------------------
# The eval harness auto-loads this .env so you don't have to prefix every
# `uv run pytest` command with these.
# ANTHROPIC_API_KEY=sk-ant-...              # required for the --llm prompt evals
# PEXIP_EVAL_MODEL=claude-sonnet-5          # model the --llm evals grade against
# PEXIP_EVAL_DIAL_TARGET=sip:test@lab.local # SIP URI/alias for the --live auto-dial test (optional)
# PEXIP_EVAL_VMR=allhands@example.com       # a real hosted VMR alias for the live-call phase
# Dialing into a hosted VMR (not a test-created one) keeps the call a conference,
# so lock / mute-guests commands are valid (gateway-routed calls reject them).
