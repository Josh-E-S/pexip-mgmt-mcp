# Pexip Management Node connection
# Use PEXIP_HOST to specify the Management Node hostname or IP
PEXIP_HOST=pexip.example.com

# --- Eval suite (evals/) ------------------------------------------------------
# The eval harness auto-loads this .env, so you can keep all eval config here
# instead of prefixing every `uv run pytest` command.
#
# ANTHROPIC_API_KEY: required for the --llm prompt evals (scored against Claude).
# ANTHROPIC_API_KEY=sk-ant-...
# PEXIP_EVAL_MODEL: model id the --llm evals grade against (default: claude-sonnet-5).
# PEXIP_EVAL_MODEL=claude-sonnet-5
# PEXIP_EVAL_DIAL_TARGET: SIP URI/alias for the --live auto-dial test (optional).
# PEXIP_EVAL_DIAL_TARGET=sip:test@lab.local
# PEXIP_EVAL_VMR: a real hosted VMR alias on your node for the live-call phase.
# Dialing into a hosted VMR (not a test-created one) keeps the call a conference
# so lock/mute-guests commands are valid (gateway-routed calls reject them).
# PEXIP_EVAL_VMR=allhands@example.com
# ------------------------------------------------------------------------------

# Use PEXIP_AUTH_MODE to choose authentication: "basic" (default) or "oauth2".
# PEXIP_AUTH_MODE=basic

# --- basic auth (PEXIP_AUTH_MODE=basic) ---
# Use PEXIP_USERNAME to specify the local admin username
PEXIP_USERNAME=username
# Use PEXIP_PASSWORD to specify the local admin password
PEXIP_PASSWORD=password

# --- oauth2 auth (PEXIP_AUTH_MODE=oauth2) ---
# OAuth2 is NOT enabled on Infinity by default: first create an Administrator
# Role + an OAuth2 client in the Pexip UI (Users & Devices > OAuth2 Clients)
# and enable Management API OAuth2. The server signs an ES256 JWT assertion
# with the private key and exchanges it at https://<host>/oauth/token/.
# PEXIP_OAUTH2_CLIENT_ID=your-client-id
# Paste the client's "Private key" (ES256 PEM, shown once on creation).
# For multi-line PEMs, quote and use \n, or load from a file in your launcher.
# PEXIP_OAUTH2_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional overrides:
# PEXIP_OAUTH2_TOKEN_URL=https://pexip.example.com/oauth/token/
# PEXIP_OAUTH2_SCOPE=is_admin use_api

# Use PEXIP_VERIFY_TLS to enforce trusted SSL certificates in production. Set to false ONLY for local testing.
PEXIP_VERIFY_TLS=true

# Use PEXIP_TIMEOUT to change the HTTP connection timeout in seconds (default: 30)
# PEXIP_TIMEOUT=30

# Use PEXIP_MAX_RETRIES to change the max retries on 429 rate-limit responses (default: 3)
# PEXIP_MAX_RETRIES=3

# Read-only mode is ON BY DEFAULT (secure by default): only read tools
# (list/get/schema) are exposed and every create/update/delete/control tool is
# removed from the catalog at startup. Set PEXIP_READ_ONLY=false to OPT IN to
# the mutating admin surface.
# PEXIP_READ_ONLY=true

# When writes are enabled (PEXIP_READ_ONLY=false), the generic CRUD tools still
# refuse to mutate security-critical resources (SSH authorized keys, admin
# roles/permissions, authentication/SSO config, TLS/CA certificates) unless you
# explicitly opt in here. Leave false unless you really need it.
# PEXIP_ALLOW_SECURITY_RESOURCES=false

# Platform-lifecycle command tools (backup create/restore, certificate import,
# platform upgrade, software-bundle upload, cloud-node start, snapshot) are
# removed at startup even with writes enabled, unless you opt in here. Misuse of
# any of these can replace or compromise the whole platform. Leave false unless
# you deliberately need agent-driven platform lifecycle operations.
# PEXIP_ALLOW_PLATFORM_TOOLS=false

# --- Downstream auth: how HTTP clients authenticate to THIS server ---
# Only affects the --http transport; stdio needs none of this. See docs/identity.md.
#
# PEXIP_MCP_AUTH_MODE: "token" (default, static bearer token) or "oauth" (validate
# OIDC bearer JWTs from your own IdP — Entra/Google/Okta/on-prem).
# PEXIP_MCP_AUTH_MODE=token

# token mode: a shared secret set here AND sent by the client as
# "Authorization: Bearer <value>". REQUIRED for a non-loopback bind. Must be >= 32
# chars (server refuses shorter). Generate one:  pexip-mgmt-mcp --generate-token
# PEXIP_MCP_TOKEN=replace-with-long-random-string

# oauth mode (PEXIP_MCP_AUTH_MODE=oauth): point at an OIDC provider you already run.
# Issuer + audience are required; JWKS is discovered from the issuer if not set.
# PEXIP_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# PEXIP_OIDC_AUDIENCE=api://pexip-mcp
# PEXIP_OIDC_REQUIRED_SCOPES=pexip.read pexip.write
# PEXIP_OIDC_JWKS_URI=https://your-idp/.well-known/jwks.json
